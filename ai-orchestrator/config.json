{
    "name": "AI Orchestrator",
    "version": "0.13.4",
    "slug": "ai-orchestrator",
    "description": "Microsoft Defender-inspired Home Assistant control portal with Gemma 4 E4B profiles, deterministic guarded tools, durable plans, memory, triggers, and streaming",
    "url": "https://github.com/ITSpecialist111/HASS-AI-Orchestrator",
    "arch": [
        "amd64",
        "armv7",
        "aarch64"
    ],
    "startup": "application",
    "boot": "auto",
    "host_network": true,
    "init": false,
    "ingress": true,
    "ingress_port": 8999,
    "ingress_entry": "/",
    "panel_icon": "mdi:robot",
    "map": [
        "addon_config:rw"
    ],
    "hassio_api": true,
    "hassio_role": "default",
    "homeassistant_api": true,
    "options": {
        "ollama_host": "http://localhost:11434",
        "dry_run_mode": true,
        "log_level": "info",
        "ha_url": "",
        "ha_access_token": "",
        "decision_interval": 120,
        "enable_rag": true,
        "enable_gpu": false,
        "smart_model": "gemma4:e4b",
        "fast_model": "gemma4:e4b",
        "orchestrator_model": "gemma4:e4b",
        "allowed_domains": "light,switch,fan,climate,media_player,cover,input_boolean,input_select,input_number,scene,button,vacuum,water_heater,lock,alarm_control_panel,camera",
        "blocked_domains": "shell_command,hassio,script,automation,rest_command",
        "high_impact_services": "lock.unlock,lock.lock,alarm_control_panel.alarm_disarm,alarm_control_panel.alarm_arm_home,alarm_control_panel.alarm_arm_away,camera.disable_motion_detection,camera.turn_off",
        "min_temp": 10.0,
        "max_temp": 30.0,
        "max_temp_change": 3.0,
        "disable_telemetry": true,
        "gemini_api_key": "",
        "use_gemini_for_dashboard": false,
        "gemini_model_name": "gemini-robotics-er-1.5-preview",
        "mcp_server_url": "",
        "mcp_server_token": "",
        "deep_reasoning_model": "gemma4:e4b",
        "reasoning_default_profile": "balanced",
        "deep_reasoning_max_iterations": 20,
        "reasoning_max_tool_calls": 48,
        "reasoning_max_seconds": 420,
        "reasoning_llm_timeout": 240,
        "reasoning_tool_timeout": 30,
        "reasoning_effort": "medium",
        "reasoning_max_concurrent_runs": 1,
        "reasoning_allow_direct_execute": false,
        "enable_legacy_autonomous_loops": false,
        "enable_legacy_dashboard_loop": false,
        "anthropic_api_key": "",
        "anthropic_model": "claude-opus-4-8",
        "llm_provider": "ollama",
        "openai_api_key": "",
        "openai_base_url": "",
        "openai_model": "gpt-5.6-terra",
        "github_token": "",
        "github_model": "gpt-4o-mini",
        "foundry_endpoint": "",
        "foundry_api_key": "",
        "foundry_bearer_token": "",
        "foundry_model": "",
        "foundry_agent_id": "",
        "api_token": ""
    },
    "schema": {
        "ollama_host": "str",
        "dry_run_mode": "bool",
        "log_level": "list(debug|info|warning|error)",
        "ha_url": "str?",
        "ha_access_token": "str?",
        "decision_interval": "int(30,600)",
        "enable_rag": "bool",
        "enable_gpu": "bool",
        "smart_model": "str",
        "fast_model": "str",
        "orchestrator_model": "str",
        "allowed_domains": "str",
        "blocked_domains": "str",
        "high_impact_services": "str",
        "min_temp": "float",
        "max_temp": "float",
        "max_temp_change": "float",
        "disable_telemetry": "bool",
        "gemini_api_key": "str?",
        "use_gemini_for_dashboard": "bool",
        "gemini_model_name": "str",
        "mcp_server_url": "str?",
        "mcp_server_token": "str?",
        "deep_reasoning_model": "str",
        "reasoning_default_profile": "list(rapid|balanced|deep)",
        "deep_reasoning_max_iterations": "int(1,40)",
        "reasoning_max_tool_calls": "int(1,200)",
        "reasoning_max_seconds": "int(10,1800)",
        "reasoning_llm_timeout": "int(5,600)",
        "reasoning_tool_timeout": "int(1,300)",
        "reasoning_effort": "list(low|medium|high|xhigh|max)",
        "reasoning_max_concurrent_runs": "int(1,8)",
        "reasoning_allow_direct_execute": "bool",
        "enable_legacy_autonomous_loops": "bool",
        "enable_legacy_dashboard_loop": "bool",
        "anthropic_api_key": "str?",
        "anthropic_model": "str",
        "llm_provider": "list(ollama|openai|anthropic|github|foundry)?",
        "openai_api_key": "str?",
        "openai_base_url": "str?",
        "openai_model": "str?",
        "github_token": "str?",
        "github_model": "str?",
        "foundry_endpoint": "str?",
        "foundry_api_key": "str?",
        "foundry_bearer_token": "str?",
        "foundry_model": "str?",
        "foundry_agent_id": "str?",
        "api_token": "str?"
    }
}